{
  "schema": "aoa_course_corpus_integrity_eval_suite_v1",
  "suite_id": "corpus-integrity",
  "requirements": {
    "fixture_platforms": ["getcourse", "skillspace", "stepik"],
    "minimum_fixture_source_count": 3,
    "probe_limit": 12,
    "recall_k": 5,
    "min_recall_at_k": 1.0,
    "mode": "hybrid",
    "require_keyword_coverage": 1.0,
    "require_semantic_alignment": 1.0,
    "require_graph_coverage": 1.0,
    "require_evidence_attribution": 1.0,
    "require_lexical_retrievability": 1.0,
    "require_semantic_vector_coverage": 1.0,
    "require_zero_dangling_graph_edges": true,
    "require_zero_invalid_inverted_postings": true
  }
}
