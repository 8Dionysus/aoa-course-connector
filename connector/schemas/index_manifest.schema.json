{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aoa_course_index_manifest.schema.json",
  "title": "IndexManifest",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "doc_count"
  ],
  "properties": {
    "schema": {
      "enum": [
        "aoa_course_keyword_index_v1",
        "aoa_course_semantic_index_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "doc_count": {
      "type": "integer"
    },
    "term_count": {
      "type": "integer"
    },
    "provider": {
      "type": "string"
    },
    "provider_config": {
      "type": "object"
    },
    "dimensions": {
      "type": "integer"
    },
    "feature_contract": {
      "type": "object"
    }
  },
  "oneOf": [
    {
      "properties": {
        "schema": {
          "const": "aoa_course_keyword_index_v1"
        }
      },
      "required": [
        "schema",
        "run_id",
        "doc_count",
        "term_count",
        "feature_contract"
      ]
    },
    {
      "properties": {
        "schema": {
          "const": "aoa_course_semantic_index_v1"
        }
      },
      "required": [
        "schema",
        "run_id",
        "doc_count",
        "provider",
        "provider_config",
        "dimensions",
        "feature_contract"
      ]
    }
  ]
}
