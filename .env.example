# Portable course connector storage roots.
# Public docs must not assume this machine's private paths as defaults.
AOA_COURSE_DATA_ROOT=.connector-state/data
AOA_COURSE_CACHE_ROOT=.connector-state/cache
AOA_COURSE_AUTH_ROOT=.connector-state/auth
AOA_COURSE_ARTIFACT_ROOT=.connector-state/artifacts

# Optional family/instance shortcuts.
# AOA_COURSE_FAMILY_ROOT=/srv/abyss-machine/storage/connectors
# AOA_COURSE_INSTANCE_ROOT=/srv/abyss-machine/storage/connectors/aoa-course-connector
